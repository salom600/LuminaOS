#!/bin/sh
# ============================================================================
#  LuminaOS — first-boot script
#  Runs once on the first boot after install (via OpenRC service).
# ============================================================================
set -eu

LOG=/var/log/lumina-first-boot.log
echo "=== LuminaOS first-boot $(date) ===" >> "$LOG"

# 1. Set up zram swap (50% of RAM, lz4) — gives low-RAM machines breathing room
TOTAL_RAM=$(free -m | awk '/^Mem:/ {print $2}')
ZRAM_SIZE=$((TOTAL_RAM / 2))
if [ "$ZRAM_SIZE" -gt 0 ] && ! swapon --show | grep -q zram; then
    modprobe zram 2>/dev/null || true
    echo lz4 > /sys/block/zram0/comp_algorithm 2>/dev/null || true
    echo "${ZRAM_SIZE}M" > /sys/block/zram0/disksize 2>/dev/null || true
    mkswap /dev/zram0 2>/dev/null || true
    swapon -p 100 /dev/zram0 2>/dev/null || true
    echo "[+] zram swap enabled (${ZRAM_SIZE}M)" >> "$LOG"
fi

# 2. Detect GPU and recommend driver
if lspci -nnk | grep -q -i 'nvidia'; then
    echo "[i] Nvidia GPU detected — user can install nvidia-driver from Lumina Store" >> "$LOG"
fi

# 3. Set up Flatpak + Flathub if flatpak is installed
if command -v flatpak >/dev/null 2>&1; then
    flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true
    echo "[+] Flathub remote added" >> "$LOG"
fi

# 4. Enable NetworkManager autoconnect for all connections
nmcli -t -f UUID connection show 2>/dev/null | while read -r uuid; do
    nmcli connection modify "$uuid" connection.autoconnect yes 2>/dev/null || true
done

# 5. Mark the run-once service as complete so it doesn't run again
touch /var/lib/lumina/first-boot.done
mkdir -p /var/lib/lumina

echo "=== first-boot complete ===" >> "$LOG"

# 6. Disable ourselves for next boot
rc-update del lumina-first-boot default 2>/dev/null || true

exit 0
